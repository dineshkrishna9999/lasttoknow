# ──────────────────────────────────────────────
# LastToKnow — LLM Configuration
# Copy this to .env and fill in your values
# Any LiteLLM-supported model works!
# ──────────────────────────────────────────────

# Azure OpenAI
AZURE_API_KEY=your_azure_api_key
AZURE_API_BASE=your_azure_endpoint
AZURE_API_VERSION=2024-10-01-preview
LASTTOKNOW_MODEL=azure/gpt-4.1

# OpenAI
# OPENAI_API_KEY=your_key
# LASTTOKNOW_MODEL=gpt-4o

# Google Gemini
# GEMINI_API_KEY=your_key
# LASTTOKNOW_MODEL=gemini/gemini-2.0-flash

# Anthropic Claude
# ANTHROPIC_API_KEY=your_key
# LASTTOKNOW_MODEL=anthropic/claude-sonnet-4-20250514

# Local Ollama (free, no API key needed!)
# LASTTOKNOW_MODEL=ollama/llama3

# ──────────────────────────────────────────────
# Optional: GitHub token for higher API rate limits
# (Without this, GitHub API limits to 60 requests/hour)
# ──────────────────────────────────────────────
# GITHUB_TOKEN=ghp_your_token_here
